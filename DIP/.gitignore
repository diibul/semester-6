# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual Environment
venv/
env/
.env
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (tidak di-push ke GitHub karena bisa besar)
# Uncomment jika ingin push dataset:
# data/raw/*.csv
# data/processed/*.csv

# Logs
logs/*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Credentials / API Keys
*.env
secrets.py
credentials.json
token.json
